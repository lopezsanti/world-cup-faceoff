entrypoint = "main.py"
language = "python3"
run = "gunicorn --bind 0.0.0.0:8080 --workers 1 --timeout 120 main:app"
modules = ["python-3.12", "web", "nodejs-20", "nix"]

[nix]
channel = "stable-25_05"
packages = ["glibcLocales"]

[deployment]
run = ["sh", "-c", "gunicorn --bind 0.0.0.0:8080 --workers 1 --timeout 120 main:app"]
deploymentTarget = "cloudrun"

[[ports]]
localPort = 8080
externalPort = 80

[agent]
expertMode = true
